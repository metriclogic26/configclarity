{
  "redirects": [
    { "source": "/ssl/", "destination": "/ssl", "permanent": true },
    { "source": "/firewall/", "destination": "/firewall", "permanent": true },
    { "source": "/proxy/", "destination": "/proxy", "permanent": true },
    { "source": "/docker/", "destination": "/docker", "permanent": true },
    { "source": "/robots/", "destination": "/robots", "permanent": true },
    { "source": "/crontab/", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/",          "destination": "/home/index.html" },
    { "source": "/crontab",   "destination": "/" },
    { "source": "/ssl",       "destination": "/ssl/index.html" },
    { "source": "/docker",    "destination": "/docker/index.html" },
    { "source": "/firewall",  "destination": "/firewall/index.html" },
    { "source": "/proxy",     "destination": "/proxy/index.html" },
    { "source": "/robots",    "destination": "/robots/index.html" }
  ]
}
